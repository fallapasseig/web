---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'Turisme - Falla Passeig',
  description:
    'Descobreix Tavernes de la Valldigna amb la Falla Passeig. Turisme, gastronomia i els Objectius de Desenvolupament Sostenible.',
};

const sections = [
  {
    title: 'Viu Tavernes',
    description:
      'Descobreix Tavernes de la Valldigna en diversos idiomes. Informació turística sobre la nostra localitat i comarca.',
    href: '/web/viu-tavernes',
    icon: '🏠',
  },
  {
    title: 'Gastronomia',
    description:
      'Explora la rica tradició gastronòmica de Tavernes i la nostra falla. Plats típics i receptes tradicionals.',
    href: '/web/gastronomia',
    icon: '🍽️',
  },
  {
    title: 'ODS',
    description:
      'Objectius de Desenvolupament Sostenible. El nostre compromís amb la sostenibilitat i el medi ambient.',
    href: '/web/ods',
    image: imgOds,
  },
  {
    title: 'La ruta de l’aigua',
    description: 'Descobreix la ruta de l’aigua a Tavernes de la Valldigna, un recorregut natural fascinant.',
    href: '/web/ruta-aigua',
    icon: '💧',
  },
  {
    title: 'Explicació monuments',
    description: 'Descobreix els nostres monuments fallers: el monument gran i el monument infantil.',
    href: '/web/monuments',
    icon: '🎨',
  },
];

import imgOds from '~/assets/images/ods/E_WEB_17.png';
import { Image } from 'astro:assets';
---

<Layout metadata={metadata}>
  <HeroText title="Turisme">
    <Fragment slot="content">
      <div class="max-w-3xl mx-auto">
        <p class="mb-6 text-justify">
          Benvinguts a la secció de turisme de la Falla Passeig. Ací trobareu informació sobre la nostra localitat,
          gastronomia i el nostre compromís amb la sostenibilitat.
        </p>
      </div>
    </Fragment>
  </HeroText>

  <section class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex flex-col gap-6">
      {
        sections.map((section) => (
          <a
            href={section.href}
            class="group flex flex-col md:flex-row items-start md:items-center gap-4 p-6 rounded-lg border border-gray-200 dark:border-gray-800 shadow hover:shadow-xl transition-all duration-300 hover:scale-[1.02]"
          >
            <div class="flex-shrink-0">
              {section.image ? (
                <Image src={section.image} alt={section.title} class="w-24 h-24 object-contain" />
              ) : (
                <div class="text-6xl">{section.icon}</div>
              )}
            </div>
            <div class="flex-grow">
              <h2 class="text-2xl font-bold text-gray-900 dark:text-white group-hover:text-accent transition-colors mb-2">
                {section.title}
              </h2>
              <p class="text-gray-600 dark:text-gray-400">{section.description}</p>
            </div>
            <div class="flex-shrink-0 text-accent text-2xl">→</div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
