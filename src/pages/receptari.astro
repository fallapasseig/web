---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'Receptari - Falla Passeig',
  description: 'El receptari de la Falla Passeig. Receptes de plats tradicionals, dolços i molt més.',
};
---

<link href="/web/dflip/css/dflip.min.css" rel="stylesheet" type="text/css" />
<link href="/web/dflip/css/themify-icons.min.css" rel="stylesheet" type="text/css" />

<Layout metadata={metadata}>
  <HeroText title="Receptari">
    <Fragment slot="content">
      <div class="max-w-3xl mx-auto">
        <p class="mb-6 text-justify">
          Recull de les millors receptes de la nostra terra, compartides pels fallers i falleres de la nostra comissió.
          Descobreix els secrets dels nostres plats més tradicionals.
        </p>
      </div>
    </Fragment>
  </HeroText>

  <section class="max-w-5xl mx-auto px-4 py-8">
    <div class="prose dark:prose-invert max-w-none">
      <div
        class="_df_book"
        height="auto"
        webgl="true"
        source="https://media.githubusercontent.com/media/fallapasseig/static/main/g
astronomia.pdf"
        id="df_manual_book"
        view-mode="single"
        data-config='{"pageMode": 1}'
      >
      </div>
      <script src="/web/dflip/js/libs/jquery.min.js" type="text/javascript"></script>
      <script src="/web/dflip/js/dflip.min.js" type="text/javascript"></script>
    </div>
  </section>
</Layout>
