---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import { Image } from 'astro:assets';

import mg2026 from '~/assets/images/mg-2026.jpeg';

const audios = [
  { lang: 'Valencià', href: 'https://on.soundcloud.com/T1VFMYBucbf9aFxSZk', flag: '🏠' },
  { lang: 'Castellano', href: 'https://on.soundcloud.com/TYRa32S2s1BASKlH1x', flag: '🇪🇸' },
  { lang: 'English', href: 'https://on.soundcloud.com/OIq5syvuwz9pKkvrQv', flag: '🇬🇧' },
  { lang: 'Français', href: 'https://on.soundcloud.com/zjhbp64WiadSzO8RPe', flag: '🇫🇷' },
  { lang: 'Deutsch', href: 'https://on.soundcloud.com/oBxpU9E6ULfy30HqU7', flag: '🇩🇪' },
  { lang: 'Italiano', href: 'https://on.soundcloud.com/IXIVxUGRm32kgMGQ8v', flag: '🇮🇹' },
  { lang: '日本語', href: 'https://on.soundcloud.com/KNgFroTofCBrmTqkRc', flag: '🇯🇵' },
];

const metadata = {
  title: 'Monument Gran - Falla Passeig',
  description: 'Explicació i detalls del monument gran de la Falla Passeig.',
};
---

<Layout metadata={metadata}>
  <HeroText title="Monument Gran" />

  <section class="max-w-5xl mx-auto px-4 py-8">
    <p class="mb-4 text-center text-muted dark:text-slate-400">
      Pots escoltar l’explicació del monument gran en diferents idiomes.
    </p>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-7 gap-4 mb-12">
      {
        audios.map((t) => (
          <a
            href={t.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center p-4 rounded-lg border border-gray-200 dark:border-gray-800 shadow hover:shadow-lg transition-shadow duration-300"
          >
            <span class="text-4xl mb-2">{t.flag}</span>
            <span class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-accent transition-colors">
              {t.lang}
            </span>
          </a>
        ))
      }
    </div>

    <div class="max-w-3xl mx-auto text-justify">
      <p class="mb-6">
        Observa la falla amb atenció i llig la seua crítica per a entendre què representa cada escena i la sàtira que
        amaga. Si vols, també pots escoltar una explicació general del monument. L’àudio està disponible en valencià i
        en altres idiomes. Esperem que la disfrutes!.
      </p>
    </div>

    <div class="mt-12 flex justify-center">
      <div
        class="max-w-4xl w-full rounded-lg overflow-hidden shadow-lg border border-gray-200 dark:border-gray-800 transition-transform duration-300 hover:scale-[1.01]"
      >
        <Image src={mg2026} alt="Monument Gran 2026" class="w-full h-auto object-contain" loading="lazy" />
      </div>
    </div>
  </section>
</Layout>
