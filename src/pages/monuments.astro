---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'Explicació monuments - Falla Passeig',
  description: 'Descobreix els nostres monuments fallers: monument gran i monument infantil.',
};

const sections = [
  {
    title: 'Monument Gran',
    description: 'Descobreix el significat i la història del nostre monument gran d’aquest any.',
    href: '/web/monument-gran',
    icon: '🔥',
  },
  {
    title: 'Monument Infantil',
    description: 'Coneix tots els detalls del nostre monument infantil i la seua temàtica.',
    href: '/web/monument-infantil',
    icon: '🧸',
  },
];
---

<Layout metadata={metadata}>
  <HeroText title="Explicació monuments">
    <Fragment slot="content">
      <div class="max-w-3xl mx-auto text-justify">
        <p class="mb-6">
          Les falles són art, sàtira i tradició. En aquesta secció podràs conéixer més a fons els detalls del nostre
          monument gran i infantil.
        </p>
      </div>
    </Fragment>
  </HeroText>

  <section class="max-w-5xl mx-auto px-4 py-8">
    <div class="flex flex-col gap-6">
      {
        sections.map((section) => (
          <a
            href={section.href}
            class="group flex flex-col md:flex-row items-start md:items-center gap-4 p-6 rounded-lg border border-gray-200 dark:border-gray-800 shadow hover:shadow-xl transition-all duration-300 hover:scale-[1.02]"
          >
            <div class="flex-shrink-0 text-6xl">{section.icon}</div>
            <div class="flex-grow">
              <h2 class="text-2xl font-bold text-gray-900 dark:text-white group-hover:text-accent transition-colors mb-2">
                {section.title}
              </h2>
              <p class="text-gray-600 dark:text-gray-400">{section.description}</p>
            </div>
            <div class="flex-shrink-0 text-accent text-2xl">→</div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
